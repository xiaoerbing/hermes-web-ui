{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm test *)",
      "Bash(npm run *)",
      "Bash(npx vitest *)",
      "Bash(npx playwright *)",
      "Bash(npx tsc *)",
      "Bash(npx vue-tsc *)",
      "Bash(node scripts/*)",
      "Bash(git -c http.sslVerify=false *)"
    ],
    "deny": [
      "Bash(npm publish *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(ssh *)",
      "Bash(> /dev/*)"
    ]
  }
}